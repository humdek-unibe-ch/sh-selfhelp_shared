{
    "license": "header.txt",
    "ignoreFile": ".gitignore",
    "ignore": [
        "**",
        "!**/*.ts",
        "!**/*.tsx",
        "!**/*.js",
        "!**/*.jsx",
        "!**/*.mjs",
        "!**/*.cjs",
        "!**/*.md",
        "!**/*.yml",
        "!**/*.yaml"
    ],
    "licenseFormats": {
        "ts|tsx|js|jsx|mjs|cjs": {
            "prepend": "/*",
            "append": " */",
            "eachLine": {
                "prepend": " * "
            }
        },
        "md": {
            "prepend": "<!--",
            "append": "-->"
        },
        "yml|yaml": {
            "eachLine": {
                "prepend": "# "
            }
        }
    },
    "trailingWhitespace": "TRIM"
}
